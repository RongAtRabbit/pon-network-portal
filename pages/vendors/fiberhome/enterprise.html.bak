    <link rel="stylesheet" href="../../../css/components.css">
    <link rel="stylesheet" href="../../../css/responsive.css">
    <link rel="stylesheet" href="../../../css/sidebar.css">
    <link rel="stylesheet" href="../../../css/network-diagram.css">
    <style>
        .solution-hero { background: linear-gradient(135deg, #3B82F6, #60A5FA); color: white; padding: 80px 0 60px; text-align: center; }
        .value-card { background: linear-gradient(135deg, #3B82F605, #60A5FA10); border-left: 4px solid #3B82F6; }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a href="../../../index.html" class="nav-logo">
                <span class="logo-icon">🌐</span>
                <span class="logo-text">PON Portal</span>
            </a>
            <button class="nav-toggle" id="navToggle">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <ul class="nav-menu" id="navMenu">
                <li><a href="../../../index.html" class="nav-link">首页</a></li>
                <li class="nav-dropdown">
                    <a href="#" class="nav-link">行业方案 <span class="dropdown-arrow">▼</span></a>
                    <ul class="dropdown-menu">
                        <li><a href="../huawei-f5g.html">华为 F5G</a></li>
